# Frontend (optional - only needed if re-enabling Spotify features)
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Copy your Client ID below and rename this file to .env
VITE_SPOTIFY_CLIENT_ID=

# Scripts (required for data fetching scripts in scripts/)
# Spotify: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm: https://www.last.fm/api/account
LASTFM_API_KEY=
